{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Project",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "g++ -DUNICODE -D_UNICODE (Get-ChildItem -Recurse -Filter *.cpp | Where-Object { $_.Name -ne 'main.cpp' -and $_.Name -ne 'FillingCircles.cpp' } | ForEach-Object { $_.FullName }) main.cpp -o main.exe -lgdi32 -luser32 -lcomdlg32"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
